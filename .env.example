# Configuration de la base de données
# Copiez ce fichier en .env et remplissez avec vos vraies valeurs

# === Base de données ===
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=dashmed-site_db
DB_USER=root
DB_PASS=

# === Application ===
# Mettre à 1 en développement, 0 en production
APP_DEBUG=0

# === Serveur de production ===
# Sur votre serveur, les valeurs ressemblent généralement à :
# DB_HOST=localhost (ou une adresse IP spécifique)
# DB_PORT=3306
# DB_NAME=votre_nom_de_base
# DB_USER=votre_utilisateur
# DB_PASS=votre_mot_de_passe
# APP_DEBUG=0
